# ============================================================
#  Grafix@Mirror LMS — Production .htaccess
#  Domain: lms.mirrorageconcepts.com
# ============================================================

Options -Indexes
ServerSignature Off

# ── Force HTTPS (production only — skipped on localhost) ─────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Only redirect HTTP → HTTPS on the live domain
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Redirect www → non-www (lms subdomain — keep as-is)
    RewriteCond %{HTTP_HOST} ^www\.lms\.mirrorageconcepts\.com$ [NC]
    RewriteRule ^ https://lms.mirrorageconcepts.com%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Security: Block sensitive files ──────────────────────────
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|sh|bak|swp|orig)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|package\.json|package-lock\.json|yarn\.lock)$">
    Require all denied
</FilesMatch>

# ── Block directory traversal ─────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/         - [F,L]
    RewriteRule ^database/       - [F,L]
    RewriteRule ^vendor/         - [F,L]
    RewriteRule ^logs/           - [F,L]
    RewriteRule ^tools/          - [F,L]
    RewriteRule ^certificates/   - [F,L]
    RewriteRule ^\.codex/        - [F,L]
    RewriteRule ^\.qodo/         - [F,L]
    RewriteRule ^includes/guard  - [F,L]
    RewriteRule ^includes/helpers - [F,L]
    RewriteRule ^(test-db|run_patches)\.php$ - [F,L]
</IfModule>

# ── PHP settings ─────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors        Off
    php_flag  log_errors            On
    php_value error_log             logs/php_errors.log
    php_value upload_max_filesize   10M
    php_value post_max_size         12M
    php_value max_execution_time    60
    php_value memory_limit          256M
    php_value session.cookie_httponly 1
    # cookie_secure only on HTTPS — set to 0 so localhost sessions work
    php_value session.cookie_secure   0
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite Lax
</IfModule>

# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "SAMEORIGIN"
    Header always set X-XSS-Protection          "1; mode=block"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "geolocation=(), microphone=(self), camera=(self), display-capture=(self)"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Remove server info
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ── Gzip compression ──────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# ── Browser caching for static assets ────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg         "access plus 1 year"
    ExpiresByType image/png          "access plus 1 year"
    ExpiresByType image/svg+xml      "access plus 1 year"
    ExpiresByType image/webp         "access plus 1 year"
    ExpiresByType image/x-icon       "access plus 1 year"
    ExpiresByType text/css           "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/json   "access plus 0 seconds"
    ExpiresByType text/html          "access plus 0 seconds"
</IfModule>

# ── Default document ──────────────────────────────────────────
DirectoryIndex index.php index.html
